# Customer Success Digital FTE - Environment Configuration
# Copy this file to .env and update values

# =============================================================================
# Application
# =============================================================================
APP_APP_ENV=development
APP_APP_DEBUG=true
APP_APP_HOST=0.0.0.0
APP_APP_PORT=8000

# =============================================================================
# Database - PostgreSQL with Fallback
# =============================================================================

# PRIMARY DATABASE (PostgreSQL - e.g., Neon, AWS RDS, etc.)
# Format: postgresql+asyncpg://user:password@host:port/database
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/customer_success_fte

# FALLBACK DATABASE (Used when primary fails)
# Option 1: Another PostgreSQL instance
# APP_FALLBACK_DATABASE_URL=postgresql+asyncpg://user:pass@fallback-host:5432/dbname

# Option 2: SQLite for local development (automatic fallback)
APP_FALLBACK_DATABASE_URL=sqlite+aiosqlite:///./local_fallback.db

# Individual database settings (alternative to DATABASE_URL)
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_NAME=customer_success_fte
APP_DB_USER=postgres
APP_DB_PASSWORD=postgres
APP_DB_SSL_MODE=disable

# Connection Pool
APP_DB_MIN_CONNECTIONS=5
APP_DB_MAX_CONNECTIONS=20
APP_DB_COMMAND_TIMEOUT=60

# =============================================================================
# Kafka
# =============================================================================
APP_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
APP_KAFKA_TOPIC_INBOUND=inbound_messages
APP_KAFKA_TOPIC_OUTBOUND=outbound_messages
APP_KAFKA_TOPIC_EVENTS=agent_events
APP_KAFKA_CONSUMER_GROUP_ID=digital_fte_worker

# =============================================================================
# OpenAI
# =============================================================================
APP_OPENAI_API_KEY=sk-your-api-key-here
APP_OPENAI_MODEL=gpt-4
APP_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
APP_OPENAI_MAX_TOKENS=1000
APP_OPENAI_TEMPERATURE=0.7

# =============================================================================
# Gmail API (OAuth2)
# =============================================================================
APP_GMAIL_CLIENT_ID=your-client-id
APP_GMAIL_CLIENT_SECRET=your-client-secret
APP_GMAIL_REDIRECT_URI=http://localhost:8000/callback
APP_GMAIL_REFRESH_TOKEN=your-refresh-token

# =============================================================================
# Twilio (WhatsApp)
# =============================================================================
APP_TWILIO_ACCOUNT_SID=ACxxxxxxxx
APP_TWILIO_AUTH_TOKEN=your-auth-token
APP_TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# =============================================================================
# Security
# =============================================================================
APP_SECRET_KEY=your-secret-key-change-in-production
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Logging
# =============================================================================
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=text

# =============================================================================
# Feature Flags
# =============================================================================
APP_ENABLE_SENTIMENT_ANALYSIS=true
APP_ENABLE_AUTO_ESCALATION=true
APP_ENABLE_KNOWLEDGE_BASE_LEARNING=true
APP_ENABLE_METRICS_COLLECTION=true
